---
// Subpage-Hero - FULL-BLEED Foto + Navy-Overlay + Glas (wie die Homepage).
// Jede Unterseite bekommt ein Vollbild-Bild; ohne eigenes Bild greift ein
// welt-spezifischer Default. Text liegt hell auf dem Foto, Akzentwort glüht.
import Icon from './Icon.astro';
interface Props {
  eyebrow?: string;
  title: string; // darf <em>…</em> enthalten (Akzentwort)
  subtitle?: string;
  crumb?: string;
  crumbHref?: string;
  crumbParent?: string;
  crumbParentHref?: string;
  image?: string;
  imageAlt?: string;
  ghost?: string;
  tint?: string; // bad | sauna | sport | gastro | tide
  primary?: { href: string; label: string; external?: boolean };
  secondary?: { href: string; label: string };
}
const {
  eyebrow, title, subtitle, crumb, crumbHref,
  crumbParent, crumbParentHref, image, imageAlt = '',
  ghost = 'AQUANA', tint = 'tide', primary, secondary,
} = Astro.props;

// Default-Hero-Bild pro Welt (falls die Seite kein eigenes mitgibt)
const HERO_FALLBACK: Record<string, string> = {
  tide: '/images/artikel/fzb/freibadbecken.jpg',
  bad: '/images/artikel/fzb/wellenbecken2.jpg',
  sauna: '/images/artikel/sauna/saunagarten_pool.jpg',
  sport: '/images/artikel/sport/aquacycling/aquacycling_1.jpg',
  gastro: '/images/artikel/fzb/gastro_blaster.jpg',
  aqua: '/images/artikel/fzb/freibadbecken.jpg',
};
const bg = image ?? HERO_FALLBACK[tint] ?? HERO_FALLBACK.tide;
---
<section class={`page-hero relative isolate overflow-hidden tint-${tint}`}>
  <img
    src={bg}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
    width="1600" height="900"
    loading="eager" fetchpriority="high"
    decoding="async"
  />
  <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>
  <div class="absolute inset-0 grid-overlay grid-overlay-fade opacity-40" aria-hidden="true"></div>
  <div class="glow-orb" style="width: 440px; height: 440px; top: -180px; right: -100px; background: rgb(var(--rgb-accent)); opacity: 0.2;" aria-hidden="true"></div>
  <span class="ghost-mark ghost-mark-light -right-10 -bottom-24" data-text={ghost} data-parallax="0.06" aria-hidden="true"></span>

  <div class="container-aq relative z-10 flex flex-col justify-end min-h-[clamp(400px,48vh,560px)] pt-32 pb-14 md:pt-36 md:pb-20">
    <nav class="flex items-center flex-wrap gap-2 text-[0.78rem] text-white/65 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-white transition">Start</a>
      <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
      {crumbParent && crumbParentHref && (
        <Fragment>
          <a href={crumbParentHref} class="hover:text-white transition">{crumbParent}</a>
          <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
        </Fragment>
      )}
      <span class="text-white/90 font-medium">{crumb ?? 'Seite'}</span>
    </nav>

    <div class="max-w-3xl">
      {eyebrow && (
        <span class="eyebrow eyebrow-on-photo mb-5 inline-flex items-center gap-3">
          <span class="led !w-1.5 !h-1.5" aria-hidden="true" style="background: rgb(var(--rgb-accent)); box-shadow: 0 0 0 3px rgb(var(--rgb-accent) / 0.28), 0 0 12px rgb(var(--rgb-accent)); animation: none;"></span>
          {eyebrow}
        </span>
      )}
      <h1 class="heading-xl text-balance hero-title hero-text-shadow" set:html={title} />
      {subtitle && <p class="text-lg md:text-xl text-white/85 leading-relaxed max-w-2xl mt-6 text-pretty">{subtitle}</p>}
      {(primary || secondary) && (
        <div class="flex flex-col sm:flex-row gap-3 mt-9">
          {primary && (
            <a href={primary.href} class="btn btn-tide btn-lg" {...(primary.external ? { target: '_blank', rel: 'noopener' } : {})}>
              {primary.label}
              <Icon name={primary.external ? 'ArrowUpRight' : 'ArrowRight'} size={16} strokeWidth={2.5} />
            </a>
          )}
          {secondary && <a href={secondary.href} class="btn btn-glass btn-lg">{secondary.label}</a>}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  /* dunkler Grundton, falls das Foto noch lädt (kein CLS, kein Weißblitz) */
  .page-hero { background: rgb(var(--rgb-ink-deep)); }

  /* tide-Welt: Akzent im Hero auf helles Aqua heben (dunkles tide-Blau wäre
     auf dem Navy-Overlay zu kontrastarm). Scoped-Style schlägt @layer. */
  .page-hero.tint-tide { --rgb-accent: var(--rgb-aqua); }

  /* Eyebrow + LED in heller Welt-Akzentfarbe statt im dunklen Ink-Default */
  .eyebrow-on-photo { color: rgb(var(--rgb-accent)); }

  /* Headline weiß, Akzentwort (<em> via set:html → :global) in Welt-Akzent */
  .hero-title { color: #fff; }
  .hero-title :global(em) { font-style: normal; font-weight: inherit; color: rgb(var(--rgb-accent)); }
</style>
