---
// 4-Stat-Band (AMF-Pattern). Zahl animiert (data-count), Einheit separat &
// kleiner (kein Umbruch, tabular-nums).
import { stats } from '../data/trust';
interface Props { light?: boolean }
const { light = false } = Astro.props;
---
<div class={`grid grid-cols-2 lg:grid-cols-4 gap-px rounded-2xl overflow-hidden ${light ? 'bg-white/10' : 'bg-line'}`}>
  {stats.map((s) => (
    <div class={`flex flex-col p-6 md:p-7 ${light ? 'bg-ink-deep' : 'bg-paper'} fade-in`}>
      <div class="flex items-baseline whitespace-nowrap">
        <span class="stat-num text-accent" data-count={s.value}>0</span>
        {s.suffix && <span class="stat-unit text-accent">{s.suffix.trim()}</span>}
      </div>
      <div class={`font-display font-bold text-[0.95rem] mt-2 leading-tight ${light ? 'text-white' : 'text-ink'}`}>{s.label}</div>
      {s.sub && <div class={`text-[0.85rem] mt-0.5 ${light ? 'text-white/55' : 'text-muted'}`}>{s.sub}</div>}
    </div>
  ))}
</div>

<style>
  .stat-num {
    font-family: var(--font-display); font-weight: 800;
    font-size: clamp(2.1rem, 4.2vw, 3.4rem); line-height: 1; letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }
  .stat-unit {
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(1rem, 1.7vw, 1.45rem); margin-left: 0.22rem; letter-spacing: -0.01em;
  }
</style>
