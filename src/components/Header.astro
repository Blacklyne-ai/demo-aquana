---
import { nav, ticketLink, whatsappLink } from '../data/site';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;

const isActive = (item: (typeof nav)[number]) =>
  current === item.href || (item.href !== '/' && current.startsWith(item.href));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="container-mk pt-3 md:pt-4">
    <div
      id="nav-shell"
      class="flex items-center justify-between gap-2 pl-3 pr-2 md:pl-4 md:pr-2.5 py-2 rounded-pill transition-all duration-500"
      style="background: rgba(255,255,255,0.85); backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%); border: 1px solid rgba(14,34,53,0.08); box-shadow: 0 1px 2px rgba(14,34,53,0.04), 0 8px 32px -8px rgba(14,34,53,0.14), inset 0 1px 0 0 rgba(255,255,255,0.7);"
    >
      <!-- Original-Logo (Wortmarke der alten Site, 1:1) -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label="AQUANA - Startseite">
        <img src="/logo.jpg" alt="AQUANA - Euregio Freizeitbad Würselen" width="160" height="96" class="h-8 md:h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Hauptnavigation">
        {nav.map((item) => (
          <div class="nav-dd relative">
            <a href={item.href} class={`nav-pill inline-flex items-center gap-1 ${isActive(item) ? 'active' : ''}`} aria-haspopup="true" aria-expanded="false">
              {item.label}
              <Icon name="ChevronDown" size={13} strokeWidth={2.4} class="nav-dd-chev" />
            </a>
            <div class={`nav-dd-panel ${item.children.length > 6 ? 'nav-dd-panel-wide' : ''} tint-${item.tint}`} role="menu">
              <a href={item.href} role="menuitem" class="nav-dd-head">
                <Icon name="ArrowUpRight" size={14} strokeWidth={2.4} />
                {item.label} - Übersicht
              </a>
              <div class="nav-dd-grid">
                {item.children.filter((c) => c.href !== item.href).map((c) => (
                  <a href={c.href} role="menuitem" class={`nav-dd-item ${current === c.href ? 'active' : ''}`}>{c.label}</a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-1.5">
        <!-- DE / NL Sprachschalter (NL = vorbereiteter Platzhalter, Operator-TODO) -->
        <div class="lang-switch hidden md:inline-flex" role="group" aria-label="Sprache">
          <span class="lang-on" aria-current="true">DE</span>
          <span class="lang-off" aria-disabled="true" title="Nederlandse versie in voorbereiding">NL</span>
        </div>
        <a href={whatsappLink} target="_blank" rel="noopener" class="wa-btn hidden lg:inline-flex" aria-label="WhatsApp">
          <Icon name="MessageCircle" size={17} strokeWidth={2.1} />
        </a>
        <a href={ticketLink} target="_blank" rel="noopener" class="btn btn-tide btn-sm">
          <Icon name="Ticket" size={15} strokeWidth={2.2} />
          <span class="hidden sm:inline">Tickets</span>
        </a>

        <button id="menu-toggle" class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-full transition self-center" style="color: rgb(var(--rgb-ink));" aria-label="Menü öffnen" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-2 mx-4 rounded-3xl overflow-hidden" style="background: rgba(255,255,255,0.98); backdrop-filter: blur(22px); border: 1px solid rgba(14,34,53,0.08); box-shadow: 0 30px 60px -20px rgba(6,27,54,0.3);">
    <nav class="flex flex-col p-4 max-h-[calc(100vh-7rem)] overflow-y-auto" aria-label="Mobile">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href} class="py-3 px-2 text-ink/90 hover:text-ink border-b border-line font-display font-bold transition flex items-center justify-between" style={isActive(item) ? 'color:rgb(var(--rgb-tide))' : ''}>
            {item.label}
            <Icon name="ChevronRight" size={16} strokeWidth={2.2} />
          </a>
          <div class="flex flex-col pl-3 py-1 border-b border-line">
            {item.children.filter((c) => c.href !== item.href).map((c) => (
              <a href={c.href} class="py-2 px-2 text-sm text-muted hover:text-ink transition">{c.label}</a>
            ))}
          </div>
        </Fragment>
      ))}
      <div class="grid grid-cols-2 gap-2 mt-4">
        <a href={ticketLink} target="_blank" rel="noopener" class="btn btn-tide btn-sm">
          <Icon name="Ticket" size={14} strokeWidth={2.2} /> Tickets
        </a>
        <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm">
          <Icon name="MessageCircle" size={14} strokeWidth={2.2} /> WhatsApp
        </a>
      </div>
      <div class="lang-switch self-start mt-3" role="group" aria-label="Sprache">
        <span class="lang-on" aria-current="true">DE</span>
        <span class="lang-off" aria-disabled="true" title="Nederlandse versie in voorbereiding">NL</span>
      </div>
    </nav>
  </div>
</header>

<style>
  .hamburger { display: inline-flex; flex-direction: column; justify-content: center; gap: 4px; width: 22px; height: 22px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: rgb(var(--rgb-ink)); border-radius: 2px; transition: transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55), opacity 0.25s ease; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* DE/NL Sprachschalter */
  .lang-switch {
    align-items: center; padding: 2px; border-radius: 999px; gap: 1px;
    background: rgb(var(--rgb-ink) / 0.05); border: 1px solid rgb(var(--rgb-ink) / 0.1);
    font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em;
  }
  .lang-on { padding: 0.25rem 0.6rem; border-radius: 999px; background: rgb(var(--rgb-tide)); color: #fff; }
  .lang-off { padding: 0.25rem 0.6rem; color: rgb(var(--rgb-ink) / 0.4); cursor: not-allowed; }

  .wa-btn {
    width: 38px; height: 38px; border-radius: 999px; align-items: center; justify-content: center;
    color: rgb(var(--rgb-green)); background: rgb(var(--rgb-green) / 0.1); border: 1px solid rgb(var(--rgb-green) / 0.22);
    transition: background 0.25s ease, transform 0.25s ease;
  }
  .wa-btn:hover { background: rgb(var(--rgb-green) / 0.18); transform: translateY(-1px); }

  /* Mega-Dropdown */
  .nav-dd-panel {
    position: absolute; top: calc(100% + 10px); left: 50%; transform: translateX(-50%) translateY(8px);
    min-width: 230px; padding: 0.5rem; border-radius: 18px;
    background: rgba(255,255,255,0.98); border: 1px solid rgba(14,34,53,0.08);
    backdrop-filter: blur(22px) saturate(170%); -webkit-backdrop-filter: blur(22px) saturate(170%);
    box-shadow: 0 20px 44px -16px rgba(6,27,54,0.26), inset 0 1px 0 0 rgba(255,255,255,0.7);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 60;
  }
  .nav-dd-panel-wide { min-width: 440px; }
  .nav-dd-panel-wide .nav-dd-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.1rem 0.4rem; }
  .nav-dd-panel::before { content: ""; position: absolute; left: 0; right: 0; top: -14px; height: 16px; }
  .nav-dd:hover .nav-dd-panel, .nav-dd:focus-within .nav-dd-panel { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav-dd:hover .nav-dd-chev { transform: rotate(180deg); }
  .nav-dd-head {
    display: flex; align-items: center; gap: 0.4rem; padding: 0.55rem 0.85rem; margin-bottom: 0.3rem;
    border-radius: 11px; font-family: var(--font-display); font-size: 0.78rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: rgb(var(--rgb-accent)); background: rgb(var(--rgb-accent) / 0.08);
  }
  .nav-dd-head:hover { background: rgb(var(--rgb-accent) / 0.14); }
  .nav-dd-item {
    display: block; padding: 0.55rem 0.85rem; border-radius: 11px; font-size: 0.88rem; font-weight: 600;
    font-family: var(--font-display); color: rgb(var(--rgb-ink) / 0.72);
    transition: background 0.2s ease, color 0.2s ease;
  }
  .nav-dd-item:hover { background: rgb(var(--rgb-accent) / 0.08); color: rgb(var(--rgb-accent)); }
  .nav-dd-item.active { color: rgb(var(--rgb-accent)); background: rgb(var(--rgb-accent) / 0.07); font-weight: 700; }
  .nav-dd-chev { transition: transform 0.3s ease; }
</style>

<script>
  // View-Transition-sicher: Element-Listener pro Seite neu, window/document einmalig.
  function isOpen() {
    const menu = document.getElementById('mobile-menu');
    return !!menu && !menu.classList.contains('hidden');
  }
  function setOpen(open: boolean) {
    const menu = document.getElementById('mobile-menu');
    const toggle = document.getElementById('menu-toggle');
    const burger = toggle?.querySelector('.hamburger');
    if (!menu) return;
    menu.classList.toggle('hidden', !open);
    burger?.classList.toggle('open', open);
    if (toggle) {
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
    }
    document.body.style.overflow = open ? 'hidden' : '';
  }

  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', (e) => { e.stopPropagation(); setOpen(!isOpen()); });
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.body.style.overflow = '';
  });

  const w = window as any;
  if (!w.__aqHeader) {
    w.__aqHeader = true;
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen()) setOpen(false); });
    document.addEventListener('click', (e) => {
      const header = document.getElementById('site-header');
      if (isOpen() && header && !header.contains(e.target as Node)) setOpen(false);
    });
    window.addEventListener('resize', () => { if (window.innerWidth >= 1024 && isOpen()) setOpen(false); });

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const shell = document.getElementById('nav-shell');
        const y = window.scrollY;
        if (shell) {
          if (y > 30) { shell.style.background = 'rgba(255,255,255,0.94)'; shell.style.transform = 'scale(0.985)'; }
          else { shell.style.background = 'rgba(255,255,255,0.85)'; shell.style.transform = 'scale(1)'; }
        }
        ticking = false;
      });
    }, { passive: true });
  }
</script>
