---
// News-Teaser-Card.
import Icon from './Icon.astro';
import type { NewsItem } from '../data/news';
interface Props { item: NewsItem }
const { item } = Astro.props;
---
<a href={`/aktuelles/${item.slug}`} class="card group !p-0 flex flex-col fade-in overflow-hidden">
  {item.image && (
    <div class="relative aspect-[16/10] overflow-hidden">
      <img src={item.image} alt={item.imageAlt ?? item.title} loading="lazy" width="600" height="375" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
      <span class="absolute top-3 left-3 world-badge-soft tint-tide" style="background: rgba(255,255,255,0.92); color: rgb(var(--rgb-tide)); border:none;">{item.category}</span>
    </div>
  )}
  <div class="p-6 flex flex-col flex-1">
    <span class="text-[0.78rem] font-mono text-muted-light uppercase tracking-wide">{item.date}</span>
    <h3 class="font-display font-bold text-ink text-lg leading-snug mt-2 group-hover:text-tide transition-colors">{item.title}</h3>
    <p class="text-muted text-[0.92rem] leading-relaxed mt-2.5 text-pretty flex-1">{item.teaser}</p>
    <span class="inline-flex items-center gap-1.5 mt-4 font-display font-bold text-tide text-sm">
      Weiterlesen
      <Icon name="ArrowRight" size={15} strokeWidth={2.5} class="transition-transform duration-300 group-hover:translate-x-1" />
    </span>
  </div>
</a>
