---
import { site, nav, legalNav, telLink, mailLink, whatsappLink, ticketLink } from '../data/site';
import Icon from './Icon.astro';
---
<footer class="section-ink relative overflow-hidden" role="contentinfo">
  <div class="absolute inset-0 grid-overlay grid-overlay-fade opacity-50" aria-hidden="true"></div>
  <div class="glow-orb" style="width: 420px; height: 420px; top: -160px; left: 8%; background: rgb(var(--rgb-aqua)); opacity: 0.08;" aria-hidden="true"></div>

  <div class="container-mk relative pt-16 md:pt-20 pb-8">
    <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="lg:col-span-3">
        <img src="/logo.jpg" alt="AQUANA - Euregio Freizeitbad Würselen" width="160" height="96" class="h-14 w-auto rounded-xl bg-white p-2" loading="lazy" />
        <p class="text-white/60 text-[0.95rem] leading-relaxed mt-5 max-w-xs text-pretty">
          Vier Welten, ein Bad: Freizeitbad, Saunawelt, Sport und Gastronomie - mitten in der Euregio bei Aachen, für Gäste aus Deutschland und den Niederlanden.
        </p>
        <div class="inline-flex items-center gap-2 mt-5 pill pill-dark">
          <Icon name="Award" size={14} strokeWidth={2.2} /> SaunaPremium
        </div>
        <div class="flex items-center gap-3 mt-6">
          <a href={site.facebookUrl} target="_blank" rel="noopener" aria-label="AQUANA auf Facebook" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07Z"/></svg>
          </a>
          <a href={site.instagramUrl} target="_blank" rel="noopener" aria-label="AQUANA auf Instagram" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={site.youtubeUrl} target="_blank" rel="noopener" aria-label="AQUANA auf YouTube" class="social-ico">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.2 3.6-6.2 3.6Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav-Gruppen -->
      <div class="lg:col-span-6 grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-8">
        {nav.map((group) => (
          <div>
            <h3 class="text-white text-[0.72rem] font-mono font-semibold uppercase tracking-[0.18em] mb-4">
              <a href={group.href} class="hover:text-white/70 transition">{group.label}</a>
            </h3>
            <ul class="space-y-2 text-[0.9rem]">
              {group.children.map((c) => (
                <li><a href={c.href} class="nav-link nav-link-light">{c.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- Kontakt -->
      <div class="lg:col-span-3">
        <h3 class="text-white text-[0.72rem] font-mono font-semibold uppercase tracking-[0.18em] mb-5">Kontakt</h3>
        <ul class="space-y-3 text-[0.92rem] text-white/60">
          <li class="flex items-start gap-2.5">
            <Icon name="MapPin" size={16} strokeWidth={2} class="mt-0.5 flex-shrink-0 text-white/40" />
            <span>{site.address.street}<br />{site.address.postcode} {site.address.city}</span>
          </li>
          <li>
            <a href={telLink} class="flex items-center gap-2.5 hover:text-white transition">
              <Icon name="Phone" size={16} strokeWidth={2} class="flex-shrink-0 text-white/40" />
              <span>{site.phoneDisplay}</span>
            </a>
          </li>
          <li>
            <a href={mailLink} class="flex items-center gap-2.5 hover:text-white transition break-all">
              <Icon name="Mail" size={16} strokeWidth={2} class="flex-shrink-0 text-white/40" />
              {site.email}
            </a>
          </li>
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener" class="flex items-center gap-2.5 hover:text-white transition">
              <Icon name="MessageCircle" size={16} strokeWidth={2} class="flex-shrink-0 text-white/40" />
              WhatsApp
            </a>
          </li>
        </ul>
        <a href={ticketLink} target="_blank" rel="noopener" class="btn btn-tide btn-sm mt-6">
          <Icon name="Ticket" size={14} strokeWidth={2.2} /> Tickets online kaufen
        </a>
      </div>
    </div>

    <!-- Legal bar -->
    <div class="pt-7 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <p class="text-white/40 text-[0.8rem]">
        © 2026 {site.name} · {site.legalName} · {site.registry} · USt-IdNr. {site.ustId}
      </p>
      <div class="flex items-center gap-5 text-[0.85rem]">
        {legalNav.map((l) => (
          <a href={l.href} class="nav-link nav-link-light">{l.label}</a>
        ))}
      </div>
    </div>
    <p class="text-white/25 text-[0.72rem] mt-4">Realisierung Demo: Blacklyne · Original-CI © {site.legalName}</p>
  </div>
</footer>

<style>
  .social-ico {
    width: 38px; height: 38px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center;
    color: rgb(255 255 255 / 0.7); background: rgb(255 255 255 / 0.06); border: 1px solid rgb(255 255 255 / 0.14);
    transition: all 0.25s ease;
  }
  .social-ico:hover { color: #fff; background: rgb(var(--rgb-aqua) / 0.2); border-color: rgb(var(--rgb-aqua) / 0.5); transform: translateY(-2px); }
</style>
