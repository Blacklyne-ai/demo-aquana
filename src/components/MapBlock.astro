---
// Google-Maps-Embed per Address-Query (kein API-Key nötig).
import { site } from '../data/site';
import Icon from './Icon.astro';
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<div class={`photo-frame relative ${className}`}>
  <iframe
    src={site.google.mapsEmbed}
    title="Karte - AQUANA, Willy-Brandt-Ring 100, 52146 Würselen"
    width="600"
    height="450"
    class="w-full h-full min-h-[320px]"
    style="border:0;"
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
  <a
    href={site.google.mapsUrl}
    target="_blank"
    rel="noopener"
    class="absolute bottom-4 left-4 btn btn-tide btn-sm shadow-lg"
  >
    <Icon name="Navigation" size={14} strokeWidth={2.2} />
    In Google Maps öffnen
  </a>
</div>
