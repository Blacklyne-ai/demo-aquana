---
// Schema.org - AQUANA als SportsActivityLocation/LocalBusiness.
// aggregateRating = ECHTES Google-Aggregat (3,8 / 3.787), nichts erfunden.
import { site } from '../data/site';
interface Props {
  schema?: object | null;
}
const { schema = null } = Astro.props;

const base = {
  '@context': 'https://schema.org',
  '@type': ['SportsActivityLocation', 'LocalBusiness'],
  name: `${site.name} - ${site.longName}`,
  legalName: site.legalName,
  url: site.url,
  telephone: site.phoneIntl,
  email: site.email,
  faxNumber: '+492405411920',
  foundingDate: '1998',
  image: new URL('/images/artikel/fzb/wellenbecken.jpg', site.url).toString(),
  logo: new URL('/logo.jpg', site.url).toString(),
  priceRange: '€€',
  sameAs: [site.facebookUrl, site.instagramUrl, site.youtubeUrl],
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    postalCode: site.address.postcode,
    addressCountry: site.address.countryCode,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 50.8235,
    longitude: 6.1247,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday'], opens: '15:00', closes: '19:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Saturday', 'Sunday'], opens: '10:00', closes: '19:00' },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.google.rating,
    reviewCount: site.google.reviewCount,
    bestRating: 5,
  },
};

const json = JSON.stringify(schema ? { ...base, ...schema } : base);
---
<script type="application/ld+json" set:html={json} />
