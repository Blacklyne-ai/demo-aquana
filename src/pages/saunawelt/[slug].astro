---
import ContentPageLayout from '../../components/ContentPageLayout.astro';
import { saunaPages } from '../../data/sauna';
import { worldBySlug } from '../../data/worlds';
import { nav } from '../../data/site';

export function getStaticPaths() {
  return saunaPages.map((page) => ({ params: { slug: page.slug }, props: { page } }));
}
const { page } = Astro.props;
const world = worldBySlug('/saunawelt');
const group = nav.find((g) => g.href === '/saunawelt');
const siblings = (group?.children ?? []).filter((c) => c.href !== `/saunawelt/${page.slug}`);
---
<ContentPageLayout page={page} world={world} siblings={siblings} />
