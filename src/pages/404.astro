---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { worlds } from '../data/worlds';
---
<Layout title="Seite nicht gefunden - AQUANA Würselen" noindex={true}>
  <section class="section-paper relative overflow-hidden min-h-[70vh] flex items-center pt-32 pb-20">
    <span class="ghost-mark left-1/2 -translate-x-1/2 top-20" data-text="404" aria-hidden="true"></span>
    <div class="container-mk relative z-10 text-center max-w-2xl mx-auto">
      <span class="eyebrow eyebrow-center mb-5" style="color: rgb(var(--rgb-tide))">Fehler 404</span>
      <h1 class="heading-xl section-title">Diese Seite ist wohl <em>untergetaucht.</em></h1>
      <p class="text-muted text-lg mt-5 text-pretty">Die gewünschte Seite gibt es nicht (mehr). Springen Sie zurück zur Startseite oder direkt in eine unserer vier Welten.</p>
      <div class="flex flex-wrap justify-center gap-2.5 mt-8">
        <a href="/" class="btn btn-tide btn-lg">Zur Startseite <Icon name="ArrowRight" size={15} strokeWidth={2.4} /></a>
      </div>
      <div class="flex flex-wrap justify-center gap-2 mt-5">
        {worlds.map((w) => (
          <a href={w.slug} class={`tag tint-${w.tint} hover:border-accent`}><Icon name={w.icon} size={15} strokeWidth={2.1} class="text-accent" /> {w.name}</a>
        ))}
      </div>
    </div>
  </section>
</Layout>
