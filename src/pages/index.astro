<script>
  // Newsletter ohne Backend: öffnet das Mailprogramm mit der eingegebenen Adresse.
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('nl-form') as HTMLFormElement | null;
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.querySelector('input[type=email]') as HTMLInputElement)?.value || '';
      const subject = encodeURIComponent('Newsletter-Anmeldung AQUANA');
      const body = encodeURIComponent(`Ich möchte den AQUANA-Newsletter abonnieren.\n\nE-Mail: ${email}`);
      window.location.href = `mailto:info@aquana.de?subject=${subject}&body=${body}`;
    });
  });
</script>

<style>
  /* Hero: Hintergründe crossfaden */
  .hero-bg { transition: opacity 1.1s cubic-bezier(0.4,0,0.2,1); will-change: opacity; }
  /* Akzentwort der Headline folgt der aktiven Welt */
  #hero .section-title em { color: rgb(var(--rgb-accent)); transition: color 0.7s ease; }

  /* Live-Status-Pille */
  .status-pill {
    display: inline-flex; align-items: center; gap: 0.6rem;
    padding: 0.45rem 1rem 0.45rem 0.8rem; border-radius: 999px;
    font-family: var(--font-display); font-weight: 600; font-size: 0.82rem; color: #fff;
    transition: transform 0.25s ease;
  }
  .status-pill:hover { transform: translateY(-1px); }
  .status-led { width: 9px; height: 9px; border-radius: 999px; flex-shrink: 0; background: #9aa7b3; }
  .status-led.is-open { background: rgb(var(--rgb-green)); box-shadow: 0 0 0 3px rgb(var(--rgb-green) / 0.25), 0 0 10px rgb(var(--rgb-green) / 0.8); animation: statuspulse 2.2s ease-in-out infinite; }
  .status-led.is-closed { background: #E0A23C; box-shadow: 0 0 0 3px rgb(224 162 60 / 0.22); }
  @keyframes statuspulse {
    0%,100% { box-shadow: 0 0 0 3px rgb(var(--rgb-green) / 0.25), 0 0 10px rgb(var(--rgb-green) / 0.8); }
    50% { box-shadow: 0 0 0 6px rgb(var(--rgb-green) / 0.04), 0 0 16px rgb(var(--rgb-green)); }
  }

  /* Vier-Welten-Switcher-Tabs */
  .hero-tab {
    display: flex; align-items: center; gap: 0.7rem; text-align: left; width: 100%;
    padding: 0.75rem 0.9rem; border-radius: var(--radius-lg); cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease, border-color 0.3s ease;
  }
  .hero-tab:hover { transform: translateY(-2px); }
  .hero-tab-icon {
    width: 38px; height: 38px; border-radius: 11px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgb(255 255 255 / 0.12); color: #fff; transition: background 0.3s ease, color 0.3s ease;
  }
  .hero-tab-arrow { color: rgb(255 255 255 / 0.4); transition: color 0.3s ease, transform 0.3s ease; }
  .hero-tab[aria-selected="true"] {
    background: rgb(var(--rgb-accent) / 0.16) !important;
    border-color: rgb(var(--rgb-accent) / 0.7) !important;
    box-shadow: 0 0 0 1px rgb(var(--rgb-accent) / 0.5), 0 12px 30px -12px rgb(var(--rgb-accent) / 0.6);
  }
  .hero-tab[aria-selected="true"] .hero-tab-icon { background: rgb(var(--rgb-accent)); color: #fff; }
  .hero-tab[aria-selected="true"] .hero-tab-arrow { color: #fff; transform: translate(2px,-2px); }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { transition: none; }
    .status-led.is-open { animation: none; }
  }
</style>

<script>
  // Interaktiver Hero: Vier-Welten-Switcher + Live-Status (View-Transition-sicher).
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('hero');
    if (!hero || (hero as HTMLElement).dataset.heroInit) return;
    (hero as HTMLElement).dataset.heroInit = '1';

    const bgs = [...hero.querySelectorAll<HTMLElement>('[data-hero-bg]')];
    const tabs = [...hero.querySelectorAll<HTMLElement>('[data-hero-tab]')];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let active = 0;
    let timer: number | undefined;

    function show(idx: number) {
      active = idx;
      bgs.forEach((b, i) => (b.style.opacity = i === idx ? '1' : '0'));
      const accent = tabs[idx]?.dataset.accent;
      if (accent) hero!.style.setProperty('--rgb-accent', accent);
      tabs.forEach((t, i) => t.setAttribute('aria-selected', i === idx ? 'true' : 'false'));
    }
    function start() { if (reduce) return; stop(); timer = window.setInterval(() => show((active + 1) % bgs.length), 6500); }
    function stop() { if (timer) { clearInterval(timer); timer = undefined; } }

    tabs.forEach((t, i) => {
      t.addEventListener('mouseenter', () => { show(i); stop(); });
      t.addEventListener('focus', () => { show(i); stop(); });
      t.addEventListener('click', () => { const href = t.dataset.href; if (href) window.location.href = href; });
    });
    hero.addEventListener('mouseleave', start);

    // restliche Hintergründe nach dem ersten Paint laden
    requestAnimationFrame(() => bgs.slice(1).forEach((b) => b.setAttribute('loading', 'eager')));
    start();

    // ── Live-Status (Öffnungszeiten verbatim) ──
    const schedule: Record<string, (number[] | null)[]> = {
      bad:   [[10,19], null, [15,19], [15,19], [15,19], [15,19], [10,19]], // So..Sa
      sauna: [[10,20], [10,22], [10,22], [10,22], [10,22], [10,24], [10,22]],
    };
    const dot = document.getElementById('hero-dot');
    const txt = document.getElementById('hero-status-text');
    if (dot && txt) {
      const now = new Date();
      const d = now.getDay();
      const h = now.getHours() + now.getMinutes() / 60;
      const fmt = (x: number) => (x === 24 ? '00' : String(x).padStart(2, '0')) + ':00';
      const isOpen = (s: number[] | null) => !!s && h >= s[0] && h < s[1];
      const bad = schedule.bad[d], sauna = schedule.sauna[d];
      let label: string, open: boolean;
      if (isOpen(bad)) { label = `Freizeitbad geöffnet · bis ${fmt(bad![1])} Uhr`; open = true; }
      else if (isOpen(sauna)) { label = `Sauna geöffnet · bis ${fmt(sauna![1])} Uhr`; open = true; }
      else {
        const nextOpen = [bad, sauna].filter((s) => s && h < s[0]).map((s) => s![0]).sort((a, b) => a - b)[0];
        label = nextOpen !== undefined ? `Öffnet heute um ${fmt(nextOpen)} Uhr` : 'Heute geschlossen';
        open = false;
      }
      txt.textContent = label;
      dot.classList.add(open ? 'is-open' : 'is-closed');
    }
  });
</script>
