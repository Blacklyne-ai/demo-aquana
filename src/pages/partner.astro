---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';

const partners = [
  { name: 'Erlebnisbad-Spassbad', url: 'http://www.erlebnisbad-spassbad.de/', text: 'Das Portal rund um Erlebnis- und Spaßbäder.' },
  { name: 'Aachenerkinder', url: '', text: 'Tipps und Angebote für Familien in Aachen und Umgebung.' },
];
---
<Layout title="Unsere Partner - AQUANA Würselen" description="Das AQUANA kooperiert mit Partnern aus der Region rund um Freizeit und Familie." current="/partner">
  <PageHero
    eyebrow="Gemeinsam stärker"
    title="Unsere <em>Partner.</em>"
    subtitle="Wir kooperieren mit Partnern aus der Region rund um Freizeit, Sport und Familie."
    crumb="Unsere Partner"
    tint="tide"
  />

  <section class="section-paper py-16 md:py-24">
    <div class="container-aq">
      <div class="grid sm:grid-cols-2 gap-5 max-w-3xl">
        {partners.map((p) => (
          <a href={p.url || '#'} target={p.url ? '_blank' : undefined} rel={p.url ? 'noopener' : undefined} class="card-feature tint-tide card-accent group fade-in">
            <span class="accent-tile mb-4"><Icon name="HeartHandshake" size={24} strokeWidth={1.9} /></span>
            <h3 class="font-display font-extrabold text-ink text-lg group-hover:text-accent transition-colors">{p.name}</h3>
            <p class="text-muted text-[0.92rem] leading-relaxed mt-2 text-pretty">{p.text}</p>
            {p.url && <span class="inline-flex items-center gap-1.5 mt-4 font-display font-bold text-accent text-sm">Zur Website <Icon name="ExternalLink" size={14} strokeWidth={2.3} /></span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
