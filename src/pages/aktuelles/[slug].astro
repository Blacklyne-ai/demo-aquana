---
import Layout from '../../layouts/Layout.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import NewsCard from '../../components/NewsCard.astro';
import { news } from '../../data/news';

export function getStaticPaths() {
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}
const { item } = Astro.props;
const more = news.filter((n) => n.slug !== item.slug).slice(0, 3);
const external = item.link?.href?.startsWith('http');
---
<Layout title={`${item.title} - Aktuelles AQUANA`} description={item.teaser} current="/aktuelles" ogImage={item.image}>
  <article>
    <!-- Hero -->
    <section class="section-paper relative overflow-hidden pt-32 pb-12 md:pt-40">
      <span class="ghost-mark -right-12 -top-16" data-text="NEWS" data-parallax="0.08" aria-hidden="true"></span>
      <div class="container-narrow relative z-10">
        <nav class="flex items-center gap-2 text-[0.78rem] text-muted-light mb-7" aria-label="Breadcrumb">
          <a href="/" class="hover:text-ink transition">Start</a>
          <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
          <a href="/aktuelles" class="hover:text-ink transition">Aktuelles</a>
          <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
          <span class="text-ink/70 font-medium">{item.title}</span>
        </nav>
        <span class="world-badge-soft tint-tide mb-5">{item.category}</span>
        <h1 class="heading-xl text-balance">{item.title}</h1>
        <p class="text-[0.85rem] font-mono uppercase tracking-wider text-muted-light mt-5">{item.date}</p>
      </div>
    </section>

    {item.image && (
      <section class="section-paper pb-4">
        <div class="container-narrow">
          <div class="photo-frame">
            <img src={item.image} alt={item.imageAlt ?? item.title} class="w-full aspect-[16/9] object-cover" width="900" height="506" loading="eager" />
          </div>
        </div>
      </section>
    )}

    <section class="section-paper py-12 md:py-16">
      <div class="container-narrow">
        <div class="legal-prose">
          {item.body.map((p) => <p>{p}</p>)}
        </div>
        {item.link && (
          <a href={item.link.href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined} class="btn btn-tide mt-8">
            {item.link.label}
            <Icon name={external ? 'ExternalLink' : 'ArrowRight'} size={15} strokeWidth={2.3} />
          </a>
        )}
      </div>
    </section>
  </article>

  <!-- Weitere News -->
  <section class="section-stone py-16 md:py-20 border-t border-line">
    <div class="container-mk">
      <h2 class="heading-md text-ink mb-8">Weitere <span class="text-tide">Neuigkeiten</span></h2>
      <div class="grid md:grid-cols-3 gap-5">
        {more.map((n) => <NewsCard item={n} />)}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
