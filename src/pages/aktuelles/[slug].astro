---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import NewsCard from '../../components/NewsCard.astro';
import { news } from '../../data/news';

export function getStaticPaths() {
  return news.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}
const { item } = Astro.props;
const more = news.filter((n) => n.slug !== item.slug).slice(0, 3);
const external = item.link?.href?.startsWith('http');
---
<Layout title={`${item.title} - Aktuelles AQUANA`} description={item.teaser} current="/aktuelles" ogImage={item.image}>
  <article>
    <!-- Full-Bleed-Hero: Artikelbild als Hintergrund, Kategorie + Datum als Eyebrow -->
    <PageHero
      eyebrow={`${item.category} · ${item.date}`}
      title={item.title}
      subtitle={item.teaser}
      crumb={item.title}
      crumbParent="Aktuelles"
      crumbParentHref="/aktuelles"
      image={item.image}
      imageAlt={item.imageAlt ?? item.title}
      ghost="NEWS"
      tint="tide"
    />

    <section class="section-paper py-12 md:py-16">
      <div class="container-narrow">
        <div class="legal-prose">
          {item.body.map((p) => <p>{p}</p>)}
        </div>
        {item.link && (
          <a href={item.link.href} target={external ? '_blank' : undefined} rel={external ? 'noopener' : undefined} class="btn btn-tide mt-8">
            {item.link.label}
            <Icon name={external ? 'ExternalLink' : 'ArrowRight'} size={15} strokeWidth={2.3} />
          </a>
        )}
      </div>
    </section>
  </article>

  <!-- Weitere News -->
  <section class="section-stone py-16 md:py-20 border-t border-line">
    <div class="container-aq">
      <h2 class="heading-md text-ink mb-8">Weitere <span class="text-tide">Neuigkeiten</span></h2>
      <div class="grid md:grid-cols-3 gap-5">
        {more.map((n) => <NewsCard item={n} />)}
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
